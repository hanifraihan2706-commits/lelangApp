def add_lot_entry(doc, item: dict, section: str, seq_num: int = None):
    """
    Tambahkan entri lot ke dokumen dengan struktur tanpa ruang kosong.
    """
    lot_num   = item["lot"]
    no_rangka = item["no_rangka"]
    no_mesin  = item["no_mesin"]
    desc      = _build_description(item)

    if seq_num is None:
        seq_num = lot_num

    lot_pfx  = f"Lot {lot_num}, " if section in ("SOLD", "TAP") else ""
    list_num = lot_num if section == "LIMIT" else seq_num

    if section == "LIMIT":
        limit_rp = format_rupiah(item.get("limit", 0))
        # Baris 1: Deskripsi lengkap diakhiri koma dan garis hingga margin kanan
        _line1(doc, f"{list_num}.\t{lot_pfx}{desc} {no_rangka}, Nomor Mesin {no_mesin},")
        
        # Baris 2: -- Nilai Limit -- : Rp. XX -- (Garis di semua celah)
        _label_line_triple(doc, TAB_NILAI_L, TAB_NILAI_C, "Nilai Limit", f"{limit_rp}.")
        
        # Baris 3: Separator penuh
        _full_sep(doc)

    elif section == "SOLD":
        harga_rp = format_rupiah(item.get("harga_terbentuk", 0))
        pembeli  = item.get("nama_customer", "-")
        alamat   = item.get("alamat_customer", "-")
        
        # Baris 1: Deskripsi
        _line1(doc, f"{list_num}.\t{lot_pfx}{desc} {no_rangka}, Nomor Mesin {no_mesin},")
        
        # Baris 2 & 3: Harga dan Pembeli dengan struktur garis penuh
        _label_line_triple(doc, TAB_HARGA_L, TAB_HARGA_C, "Harga Lelang", f"{harga_rp}.")
        _label_line_triple(doc, TAB_PEMB_L,  TAB_PEMB_C,  "Pembeli", f"{pembeli}, beralamat di {alamat}.")
        
        # Baris 4: Separator penuh
        _full_sep(doc)

    elif section == "TAP":
        # Baris 1: Deskripsi diakhiri titik dan garis
        _line1(doc, f"{list_num}.\t{lot_pfx}{desc} {no_rangka}, Nomor Mesin {no_mesin}.")
        
        # Baris 2: -- TAP -- (Garis kiri dan kanan)
        p_tap = _new_para(doc, left_cm=TAB_CM)
        # TAP berada di tengah (TAP_MID_POS) dengan garis penutup hingga akhir (CONTENT_W_TWIPS)
        _add_tabstops(p_tap, [(TAP_MID_POS, "dash"), (CONTENT_W_TWIPS, "dash")])
        _add_run(p_tap, "\tTAP\t")

