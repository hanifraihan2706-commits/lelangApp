def _build_description(item: dict) -> str:
    """Baris 1 deskripsi kendaraan (tanpa Rangka)."""
    jenis = "roda dua" if item.get("jenis") == "motor" else "roda empat"
    return (
        f"Satu (1) unit kendaraan {jenis}, "
        f"Merk {item['merk']}, "
        f"Model {item['model']}, "
        f"Tahun {item['tahun']}, "
        f"Warna {item['warna']}, "
        f"Nomor Polisi {item['nopol']}, "
        f"Nomor Rangka"
    )

# =====================================================================
# FUNGSI PEMBANTU (HELPER) UNTUK MULTILINE DASH LEADER
# =====================================================================

def _line1(doc, txt):
    """Baris pertama dengan nomor LOT dan garis dash hingga margin kanan."""
    p = _new_para(doc, left_cm=TAB_CM, first_cm=-TAB_CM)
    # Tab 1: Spasi setelah nomor, Tab 2: Garis dash ke margin kanan (8789 twips)
    _add_tabstops(p, [(TAB_TWIPS, None), (CONTENT_W_TWIPS, "dash")])
    _add_run(p, f"{txt}\t") # \t di akhir memicu garis dash ke kanan
    return p

def _label_line_triple(doc, tab_L, tab_C, label, value):
    """Baris label dengan 3 tab: Garis kiri, Garis tengah ke titik dua, dan Garis kanan."""
    p = _new_para(doc, left_cm=TAB_CM)
    # Tab 1: Ke label (dash), Tab 2: Ke titik dua (dash), Tab 3: Ke margin kanan (dash)
    _add_tabstops(p, [(tab_L, "dash"), (tab_C, "dash"), (CONTENT_W_TWIPS, "dash")])
    _add_run(p, f"\t{label}\t: {value}\t") # \t memicu semua garis
    return p

def _full_sep(doc):
    """Garis pemisah penuh (Full-width dash separator)."""
    p = _new_para(doc, left_cm=TAB_CM)
    _add_tabstops(p, [(CONTENT_W_TWIPS, "dash")])
    _add_run(p, "\t")
    return p

