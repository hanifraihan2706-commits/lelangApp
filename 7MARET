# Kamus Alias: Daftar kemungkinan nama kolom (Case Insensitive)
COLUMN_ALIASES = {
    "lot": ["LOT"],
    "nopol": ["NOPOL", "NOMOR POLISI", "NO POLISI", "NO. POLISI"],
    "merk": ["MERK", "MEREK"],
    "model": ["SERIES", "MODEL", "TYPE", "TIPE"], 
    "no_mesin": ["NOMOR MESIN", "NO MESIN", "NO. MESIN", "MESIN"],
    "no_rangka": ["NOMOR RANGKA", "NO RANGKA", "NO. RANGKA", "RANGKA", "CHASSIS"],
    "tahun": ["TAHUN", "YEAR"],
    "warna": ["WARNA", "COLOR"],
    "status": ["STATUS"],
    "nama_customer": ["NAMA CUSTOMER", "NAMA CUST", "PEMBELI"],
    "alamat_customer": ["ALAMAT CUSTOMER", "ALAMAT CUST", "ALAMAT"],
    "open_price": ["OPEN PRICE", "OPEN PRICE ALL", "LIMIT", "NILAI LIMIT"],
    "harga_terbentuk": ["HARGA TERBENTUK", "LAKU", "HARGA LELANG", "RESULT PRICE"],
}

def _find_header_and_map(ws, log) -> tuple:
    """
    Memindai 15 baris pertama untuk mencari Header Row (biasanya ada tulisan LOT).
    Mengembalikan (index_baris_header, dictionary_pemetaan_kolom)
    """
    header_idx = -1
    col_map = {}
    
    for idx, row in enumerate(ws.iter_rows(min_row=1, max_row=15, values_only=True), start=1):
        row_strs = [str(cell).strip().upper() for cell in row if cell is not None]
        
        if "LOT" in row_strs:
            header_idx = idx
            for col_i, cell in enumerate(row):
                if cell is None: continue
                cell_val = str(cell).strip().upper()
                
                for key, aliases in COLUMN_ALIASES.items():
                    if key not in col_map: 
                        if any(alias in cell_val for alias in aliases):
                            col_map[key] = col_i
                            
                if "TYPE" == cell_val and "type_col" not in col_map:
                    col_map["type_col"] = col_i
            break
            
    if header_idx != -1:
        log(f"   🔍 Header terdeteksi otomatis pada baris ke-{header_idx}")
    return header_idx, col_map


def read_excel_data(excel_path: str, sheet_name: str, log_cb=None) -> list:
    """
    Membaca data dari Excel secara DINAMIS tanpa patokan indeks mati.
    """
    def log(msg):
        if log_cb:
            log_cb(msg)

    wb  = openpyxl.load_workbook(excel_path, data_only=True)
    ws  = wb[sheet_name]
    jenis = "motor" if "MOTOR" in sheet_name.upper() else "mobil"

    header_idx, col_map = _find_header_and_map(ws, log)
    
    if header_idx == -1 or "lot" not in col_map:
        log("❌ Gagal mendeteksi kolom! Pastikan ada baris Header yang mengandung kata 'LOT'.")
        return []

    items = []
    
    for row in ws.iter_rows(min_row=header_idx + 1, values_only=True):
        
        def _get(col_key):
            idx = col_map.get(col_key, -1)
            if idx < 0 or idx >= len(row):
                return None
            return row[idx]

        lot_val = _get("lot")
        if lot_val is None:
            continue
        try:
            lot_num = int(lot_val)
        except (ValueError, TypeError):
            continue

        model_raw = _get("model")
        if (model_raw is None or str(model_raw).strip() in ("-", "")) and "type_col" in col_map:
            type_idx = col_map["type_col"]
            if type_idx < len(row):
                model_raw = row[type_idx]

        no_mesin_raw  = _get("no_mesin")
        if isinstance(no_mesin_raw, float):
            no_mesin_raw = int(no_mesin_raw)

        status_raw = safe_str(_get("status"), "Not Sold")
        status_norm = status_raw.strip().upper()

        item = {
            "lot"             : lot_num,
            "nopol"           : safe_str(_get("nopol")),
            "merk"            : safe_str(_get("merk")),
            "model"           : safe_str(model_raw),
            "no_mesin"        : safe_str(no_mesin_raw),
            "no_rangka"       : safe_str(_get("no_rangka")),
            "tahun"           : safe_str(_get("tahun")),
            "warna"           : safe_str(_get("warna")),
            "status"          : status_norm,
            "nama_customer"   : safe_str(_get("nama_customer")),
            "alamat_customer" : safe_str(_get("alamat_customer")),
            "limit"           : _get("open_price") or 0,
            "harga_terbentuk" : _get("harga_terbentuk") or 0,
            "jenis"           : jenis,
        }
        items.append(item)

    log(f"   ✅ Total lot terbaca: {len(items)}")
    return items

# ══════════════════════════════════════════════════════════════════
#  SECTION TYPE RESOLVER
# ══════════════════════════════════════════════════════════════════

def resolve_section(status: str) -> str:
    """
    'SOLD'     → 'SOLD'
    'NOT SOLD' / 'NOTSOLD' → 'LIMIT'
    'CANCEL' / 'TAP' / lainnya → 'TAP'
    """
    s = status.upper().replace(" ", "")
    if s == "SOLD":
        return "SOLD"
    if s in ("NOTSOLD", ""):
        return "LIMIT"
    return "TAP"   # CANCEL, TAP, dll

