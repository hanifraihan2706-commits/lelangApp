    def _browse_excel(self):
        path = filedialog.askopenfilename(
            title="Pilih File Excel",
            filetypes=[("Excel", "*.xlsx *.xls"), ("All", "*.*")]
        )
        if not path:
            return
        self._excel_var.set(path)
        base = os.path.splitext(path)[0]
        ts = datetime.now().strftime("%Y%m%d_%H%M")
        self._output_var.set(f"{base}_RISALAH_{ts}.docx")
        self._log(f"📂 File: {os.path.basename(path)}")

        # Auto-detect sheets
        try:
            wb = openpyxl.load_workbook(path, read_only=True)
            known = ["FIRMAN", "FIRMAN BATAL", "RL II MOTOR"]
            available = [s for s in known if s in wb.sheetnames]
            wb.close()
            if available:
                self._sheet_combo["values"] = available
                self._sheet_var.set(available[0])
                self._log(f"📊 Sheet tersedia: {', '.join(available)}")
        except Exception as e:
            self._log(f"⚠️  Sheet detection error: {e}")

    def _browse_output(self):
        path = filedialog.asksaveasfilename(
            title="Simpan Sebagai",
            defaultextension=".docx",
            filetypes=[("Word", "*.docx"), ("All", "*.*")]
        )
        if path:
            self._output_var.set(path)

    def _on_generate(self):
        excel = self._excel_var.get().strip()
        output = self._output_var.get().strip()
        sheet = self._sheet_var.get().strip()

        if not excel:
            messagebox.showerror("Input", "Pilih file Excel terlebih dahulu!")
            return
        if not os.path.exists(excel):
            messagebox.showerror("Input", f"File tidak ditemukan:\n{excel}")
            return
        if not output:
            messagebox.showerror("Input", "Tentukan path output!")
            return

        meta = {k: v.get().strip() for k, v in self._meta_vars.items()}
        self._gen_btn.config(state="disabled", text="⏳  Sedang diproses...")
        self._open_btn.config(state="disabled")
        self._prog_var.set(0)
        self._log("\n" + "═" * 50)
        self._log("🚀 Memulai generasi dokumen...")
        self._set_status("Memproses...")

        def worker():
            success, result = generate_doc(
                excel_path=excel,
                output_path=output,
                sheet_name=sheet,
                meta=meta,
                progress_cb=self._set_progress,
                log_cb=self._log,
            )

            def finish():
                self._gen_btn.config(state="normal",
                                     text="⚡  GENERATE RISALAH LELANG")
                if success:
                    self._output_path = result
                    self._open_btn.config(state="normal")
                    self._set_status(f"✅ Berhasil: {os.path.basename(result)}")
                    # Update stats
                    try:
                        items = read_excel_data(excel, sheet)
                        total = len(items)
                        sold  = sum(1 for i in items if resolve_section(i["status"]) == "SOLD")
                        lim   = sum(1 for i in items if resolve_section(i["status"]) == "LIMIT")
                        tap   = sum(1 for i in items if resolve_section(i["status"]) == "TAP")
                        self._stat_vars["total"].set(str(total))
                        self._stat_vars["sold"].set(str(sold))
                        self._stat_vars["limit"].set(str(lim))
                        self._stat_vars["tap"].set(str(tap))
                    except Exception:
                        pass
                    messagebox.showinfo(
                        "✅ Berhasil!",
                        f"Risalah Lelang berhasil dibuat!\n\n{result}"
                    )
                else:
                    self._set_status("❌ Gagal! Cek log untuk detail.")
                    messagebox.showerror("❌ Error", f"Gagal:\n{result[:300]}")

            self.after(0, finish)

        threading.Thread(target=worker, daemon=True).start()

    def _on_open_output(self):
        path = self._output_path or self._output_var.get().strip()
        if not path or not os.path.exists(path):
            messagebox.showwarning("Peringatan", "File output tidak ditemukan!")
            return
        try:
            if sys.platform.startswith("darwin"):
                subprocess.run(["open", path], check=True)
            elif sys.platform.startswith("win"):
                os.startfile(path)  # type: ignore
            else:
                subprocess.run(["xdg-open", path], check=True)
        except Exception as e:
            messagebox.showerror("Error", f"Tidak bisa membuka file:\n{e}")

    # ── UI Helpers ────────────────────────────────────────────────

    def _log(self, msg: str):
        def _update():
            self._log_text.config(state="normal")
            ts = datetime.now().strftime("%H:%M:%S")
            self._log_text.insert(tk.END, f"[{ts}] {msg}\n")
            self._log_text.see(tk.END)
            self._log_text.config(state="disabled")
        self.after(0, _update)

    def _set_progress(self, val: int):
        def _update():
            self._prog_var.set(val)
            self._prog_label.config(text=f"{val}% selesai")
        self.after(0, _update)

    def _set_status(self, msg: str):
        def _update():
            self._status_var.set(msg)
        self.after(0, _update)

    @staticmethod
    def _font_exists(name: str) -> bool:
        try:
            import tkinter.font as tkfont
            fonts = tkfont.families()
            return name in fonts
        except Exception:
            return False


