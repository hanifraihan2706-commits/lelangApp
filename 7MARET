# ══════════════════════════════════════════════════════════════════
#  CONSTANTS  (Semua ukuran dalam Cm / Pt / Twips)
# ══════════════════════════════════════════════════════════════════
FONT_NAME      = "Arial"
FONT_SIZE_PT   = 12

PAGE_W_CM      = 21.0    # F4
PAGE_H_CM      = 33.0    # F4
MARGIN_L_CM    = 4.0
MARGIN_R_CM    = 1.5
MARGIN_T_CM    = 2.0
MARGIN_B_CM    = 2.0

# Lebar konten (21.0 - 4.0 - 1.5 = 15.5 cm)
CONTENT_W_CM   = PAGE_W_CM - MARGIN_L_CM - MARGIN_R_CM  # 15.5

# Tab stop posisi 420 twips ≈ 0.74 cm → pemisah nomor LOT & teks
TAB_TWIPS       = 420
TAB_CM          = TAB_TWIPS / 567          # ≈ 0.741 cm

# ── Tab Leader DASHES — posisi (twips dari left margin halaman) ─────────────
# WD_TAB_LEADER.DASHES mengisi ruang antara tab character dan tab stop
# secara OTOMATIS — menggantikan seluruh hardcode dash-string.
#
# Acuan Salinan Risalah 027 | TNR 12pt | F4 | hyphen ≈ 79 twips
#   29 dash → Nilai Limit → 25 dash | 34 dash → Harga Lelang → 5 dash
#   54 dash → Pembeli → 13 dash

CONTENT_W_TWIPS  = int(CONTENT_W_CM * 567)   # 8789

TAB_FULL         = CONTENT_W_TWIPS            # full-width dash separator

TAB_NILAI_L      = 2711   # 'Nilai Limit' label start  ≈ 4.78 cm
TAB_NILAI_C      = 6086   # ':' Nilai Limit            ≈ 10.73 cm

TAB_HARGA_L      = 3106   # 'Harga Lelang' label start ≈ 5.48 cm
TAB_HARGA_C      = 5101   # ':' Harga Lelang           ≈ 9.00 cm

TAB_PEMB_L       = 4686   # 'Pembeli' label start      ≈ 8.26 cm
TAB_PEMB_C       = 6613   # ':' Pembeli                ≈ 11.66 cm

TAP_MID_POS      = CONTENT_W_TWIPS // 2      # ~4394 — posisi "TAP" tengah
TAP_END_POS      = CONTENT_W_TWIPS           # 8789  — ujung kanan

# Header/footer separator (di luar lot entry)
DASH_LINE        = "-" * 70
