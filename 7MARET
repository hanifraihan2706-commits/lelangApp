        f"{len(tap_items)} ({tap_w}) lot tidak terjual/ditarik. "
        f"Risalah Lelang ini dibuat sebagai bukti pelaksanaan lelang.",
        sp_after=4, sp_before=10
    )

    p_sep = _new_para(doc, space_after_pt=0)
    _add_run(p_sep, DASH_LINE)

    # Tanda tangan
    p_ttd = _new_para(doc,
                       align=WD_ALIGN_PARAGRAPH.RIGHT,
                       space_before_pt=36, space_after_pt=48)
    _add_run(p_ttd, "Pejabat Lelang Kelas II,")

    p_name = _new_para(doc,
                        align=WD_ALIGN_PARAGRAPH.RIGHT,
                        space_after_pt=0)
    _add_run(p_name, pejabat, bold=True)

def generate_doc(excel_path: str, output_path: str,
                 sheet_name: str, meta: dict,
                 progress_cb=None, log_cb=None) -> tuple:
    """
    Main engine: Excel → Word.
    Returns (True, output_path) or (False, error_msg)
    """
    def log(m):
        if log_cb:
            log_cb(m)

    def prog(v):
        if progress_cb:
            progress_cb(v)

    try:
        # ── Validasi ──────────────────────────────────────────────
        log(f"📂 Membaca: {os.path.basename(excel_path)}")
        wb_test = openpyxl.load_workbook(excel_path, read_only=True)
        if sheet_name not in wb_test.sheetnames:
            raise ValueError(f"Sheet '{sheet_name}' tidak ditemukan! "
                             f"Tersedia: {wb_test.sheetnames}")
        wb_test.close()
        prog(10)

        # ── Baca Data ─────────────────────────────────────────────
        log(f"📊 Membaca sheet: {sheet_name}")
        items = read_excel_data(excel_path, sheet_name, log_cb=log)
        if not items:
            raise ValueError("Tidak ada data lot yang dapat dibaca dari sheet ini.")

        counts = {"SOLD": 0, "LIMIT": 0, "TAP": 0}
        for item in items:
            sec = resolve_section(item["status"])
            item["_section"] = sec
            counts[sec] += 1

        log(f"   📌 SOLD: {counts['SOLD']} | LIMIT: {counts['LIMIT']} | TAP: {counts['TAP']}")
        prog(25)

        # ── Buat Dokumen ──────────────────────────────────────────
        log("📝 Membuat dokumen Word...")
        doc = Document()
        _set_page_format(doc)
        _clear_default_para(doc)

        # Style default
        normal_style = doc.styles["Normal"]
        normal_style.font.name = FONT_NAME
        normal_style.font.size = Pt(FONT_SIZE_PT)

        prog(30)

        # ── Header ────────────────────────────────────────────────
        log("📄 Menulis header dokumen...")
        _add_header_section(doc, meta, items)
        prog(40)

        # ── Lot Entries — LIMIT → SOLD → TAP (sesuai struktur Risalah) ────
        log("🚗 Memproses setiap lot (LIMIT → SOLD → TAP)...")
        total = len(items)

        limit_items = [i for i in items if i["_section"] == "LIMIT"]
        sold_items  = [i for i in items if i["_section"] == "SOLD"]
        tap_items   = [i for i in items if i["_section"] == "TAP"]

        def _sec_hdr(title: str):
            p = _new_para(doc, space_before_pt=4, space_after_pt=2)
            _add_run(p, title)

        def _run_group(group, sec_name):
            for seq, itm in enumerate(group, start=1):
                try:
                    add_lot_entry(doc, itm, sec_name, seq_num=seq)
                except Exception as e:
                    log(f"   ⚠️  Lot {itm['lot']} error: {e}")

        processed = 0

        # Seksi 1 — Nilai Limit
        if limit_items:
            log(f"   📋 LIMIT: {len(limit_items)} lot")
            _run_group(limit_items, "LIMIT")
            processed += len(limit_items)
            prog(40 + int(processed / total * 45))

        # Seksi 2 — Barang Laku Terjual
        if sold_items:
            log(f"   💰 SOLD: {len(sold_items)} lot")
            p_sep = _new_para(doc, space_before_pt=6, space_after_pt=0)
            _add_run(p_sep, DASH_LINE)
            _sec_hdr("Barang laku terjual:")
            p_sep2 = _new_para(doc, space_after_pt=0)
            _add_run(p_sep2, DASH_LINE)
            _run_group(sold_items, "SOLD")
            processed += len(sold_items)
            prog(40 + int(processed / total * 45))

        # Seksi 3 — Barang Tidak Laku Terjual (TAP)
        if tap_items:
            log(f"   ❌ TAP: {len(tap_items)} lot")
            p_sep = _new_para(doc, space_before_pt=6, space_after_pt=0)
            _add_run(p_sep, DASH_LINE)
            _sec_hdr("Barang tidak laku terjual:")
            p_sep2 = _new_para(doc, space_after_pt=0)
            _add_run(p_sep2, DASH_LINE)
            _run_group(tap_items, "TAP")
            processed += len(tap_items)
            prog(40 + int(processed / total * 45))

        prog(87)

        # ── Penutup ───────────────────────────────────────────────
        log("✍️  Menulis bagian penutup...")
        _add_closing_section(doc, meta, items)
        prog(93)

        # ── Simpan ────────────────────────────────────────────────
        log(f"💾 Menyimpan ke: {os.path.basename(output_path)}")
        os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)
        doc.save(output_path)
        prog(100)

        log(f"✅ SELESAI — Dokumen berhasil dibuat!")
        return True, output_path

    except Exception as exc:
        import traceback
        log(f"❌ ERROR: {exc}")
        log(traceback.format_exc())
        return False, str(exc)

