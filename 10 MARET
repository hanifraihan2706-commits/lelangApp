def generate_doc(excel_path: str, output_path: str, sheet_name: str, meta: dict,
                  progress_cb=None, log_cb=None) -> tuple:
    def log(m):
        if log_cb: log_cb(m)
    def prog(v):
        if progress_cb: progress_cb(v)

    try:
        log(f"📂 Membaca: {os.path.basename(excel_path)}")
        wb_test = openpyxl.load_workbook(excel_path, read_only=True)
        if sheet_name not in wb_test.sheetnames:
            raise ValueError(f"Sheet '{sheet_name}' tidak ditemukan! Tersedia: {wb_test.sheetnames}")
        wb_test.close()
        prog(10)

        log(f"📊 Membaca sheet: {sheet_name}")
        items = read_excel_data(excel_path, sheet_name, log_cb=log)
        if not items:
            raise ValueError("Tidak ada data lot yang dapat dibaca dari sheet ini.")

        # Filter Status (Mendukung bahasa Indonesia & Inggris)
        STATUS_LAKU = ("SOLD", "TERJUAL", "LAKU")
        sold_items = [i for i in items if i["status"].strip().upper() in STATUS_LAKU]
        tap_items  = [i for i in items if i["status"].strip().upper() not in STATUS_LAKU]

        log(f"   📌 TOTAL: {len(items)} | SOLD: {len(sold_items)} | TAP: {len(tap_items)}")
        prog(25)

        log("📝 Membuat dokumen Word...")
        doc = Document()
        
        _set_page_format(doc)
        
        _clear_default_para(doc)

        normal_style = doc.styles["Normal"]
        normal_style.font.name = FONT_NAME
        normal_style.font.size = Pt(FONT_SIZE_PT)
        _clear_default_para(doc) # Pastikan fungsi ini ada di kode Mas

        prog(28)

        # ── Footer & Header ─────────────────────────────────────
        log("Menyiapkan footer per-lembar...")
        _add_footer(doc, meta)
        prog(30)

        log("Menulis header dokumen...")
        _add_header_section(doc, meta, items)
        prog(40)

        log("Memproses setiap lot...")

        def _sec_hdr(title: str):
            p = _new_para(doc, space_before_pt=12, space_after_pt=6)
            run = p.add_run(title)
            run.bold = True

        # # Seksi 1 — Nilai Limit (Semua Item)
        log(f"   📋 LIMIT: {len(items)} lot")
        for seq, itm in enumerate(items, start=1):
            try:
                # seq_num=seq memastikan nomor urut 1, 2, 3...
                add_lot_entry(doc, itm, "LIMIT", seq_num=seq)
            except Exception as e:
                log(f"   ⚠️  Lot {itm.get('lot', 'Unknown')} error: {e}")
        prog(60)

        # Seksi 2 — Barang Laku Terjual
        if sold_items:
            log(f"   💰 SOLD: {len(sold_items)} lot")
            # Garis Pemisah
            p_sep = _new_para(doc, space_before_pt=12, space_after_pt=0)
            _add_run(p_sep, "-" * 70)
            _sec_hdr("Barang laku terjual:")
            p_sep2 = _new_para(doc, space_after_pt=6)
            _add_run(p_sep2, "-" * 70)
            
            for seq, itm in enumerate(sold_items, start=1):
                try:
                    # seq_num=seq memastikan nomor urut lurus di seksi 2
                    add_lot_entry(doc, itm, "SOLD", seq_num=seq)
                except Exception as e:
                    log(f"   ⚠️  Lot {itm.get('lot', 'Unknown')} error: {e}")
        prog(80)

        # Seksi 3 — Barang Tidak Laku Terjual (TAP)
        if tap_items:
            log(f"   ❌ TAP: {len(tap_items)} lot")
            # Garis Pemisah
            p_sep = _new_para(doc, space_before_pt=12, space_after_pt=0)
            _add_run(p_sep, "-" * 70)
            _sec_hdr("Barang tidak laku terjual:")
            p_sep2 = _new_para(doc, space_after_pt=6)
            _add_run(p_sep2, "-" * 70)
            
            for seq, itm in enumerate(tap_items, start=1):
                try:
                    # seq_num=seq memastikan nomor urut lurus di seksi 3
                    add_lot_entry(doc, itm, "TAP", seq_num=seq)
                except Exception as e:
                    log(f"   ⚠️  Lot {itm.get('lot', 'Unknown')} error: {e}")
        prog(90)

        log("✍️  Menulis bagian penutup...")
        _add_closing_section(doc, meta, items)
        prog(95)

        log(f"💾 Menyimpan ke: {os.path.basename(output_path)}")
        os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)
        doc.save(output_path)
        prog(100)

        log(f"✅ SELESAI — Dokumen berhasil dibuat!")
        return True, output_path

    except Exception as exc:
        import traceback
        log(f"❌ ERROR: {exc}")
        log(traceback.format_exc())
        return False, str(exc)

