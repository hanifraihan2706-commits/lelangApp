def _set_page_format(doc: Document):
    """Setting kertas Folio 8.5 x 13 inci secara global."""
    sec = doc.sections[0]
    sec.page_width    = Cm(21.59)  # 8.5 in
    sec.page_height   = Cm(33.02)  # 13 in
    sec.left_margin   = Cm(4.0)
    sec.right_margin  = Cm(1.5)
    sec.top_margin    = Cm(2.0)
    sec.bottom_margin = Cm(2.0)

def _clear_default_para(doc: Document):
    for para in doc.paragraphs[:]:
        para._element.getparent().remove(para._element)

