def resolve_section(status: str) -> str:
    s = status.upper().replace(" ", "")
    if s in ("SOLD", "TERJUAL", "LAKU"):
        return "SOLD"
    if s in ("NOTSOLD", "TAKTERJUAL", "BELUMLAKU", ""):
        return "LIMIT"
    return "TAP"

