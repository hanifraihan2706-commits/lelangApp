# --- 1. FUNGSI AMBIL ID PERANGKAT ---

def get_hwid():
    try:
        if sys.platform == "darwin":
            cmd = "ioreg -rd1 -c IOPlatformExpertDevice | grep -E 'IOPlatformUUID' | awk '{print $3}' | tr -d '\"'"
            result = subprocess.check_output(cmd, shell=True).decode().strip()
            return result if result else "ID-MAC-TIDAK-TERDETEKSI"
        elif sys.platform == "win32":
            cmd = "wmic csproduct get uuid"
            output = subprocess.check_output(cmd, shell=True).decode().split('\n')
            return output[1].strip() if len(output) > 1 else "ID-WIN-TIDAK-TERDETEKSI"
    except Exception as e:
        return f"ERROR-ID: {str(e)[:10]}"
    return "UNKNOWN-PLATFORM"

def generate_expected_key(hwid):
    secret_salt = "LELANG_APP_PRO_2026"
    raw_key = hwid + secret_salt
    hashed_key = hashlib.sha256(raw_key.encode()).hexdigest()
    return hashed_key[:10].upper()

def check_license():
    current_id = get_hwid()
    expected_password = generate_expected_key(current_id)
    home_dir = os.path.expanduser("~")
    license_file = os.path.join(home_dir, "Documents", "lisensi.key")

    if os.path.exists(license_file):
        with open(license_file, "r") as f:
            saved_password = f.read().strip()
        if saved_password == expected_password:
            return

    root_auth = tk.Tk()
    root_auth.withdraw()
    pesan = (f"Aplikasi Risalah Lelang belum diaktivasi.\n\n"
             f"ID Perangkat Anda:\n{current_id}\n\n"
             f"Silakan Salin/Foto ID ini dan kirimkan ke Hanif Raihan untuk membeli Password Aktivasi.")
    messagebox.showwarning("Aktivasi Diperlukan", pesan)
    user_input = simpledialog.askstring("Input Password",
                                        "Masukkan Password Aktivasi Anda:",
                                        parent=root_auth)
    if user_input and user_input.strip().upper() == expected_password:
        with open(license_file, "w") as f:
            f.write(user_input.strip().upper())
        messagebox.showinfo("Sukses", "Aktivasi berhasil! Aplikasi siap digunakan.")
        root_auth.destroy()
    else:
        messagebox.showerror("Akses Ditolak", "Password salah atau dibatalkan. Program ditutup.")
        root_auth.destroy()
        sys.exit()


