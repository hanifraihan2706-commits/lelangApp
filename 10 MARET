def _build_description(item: dict) -> str:
    jenis = "roda dua" if item.get("jenis") == "motor" else "roda empat"
    return (
        f"Satu (1) unit kendaraan {jenis}, "
        f"Merk {item['merk']}, "
        f"Model {item['model']}, "
        f"Tahun {item['tahun']}, "
        f"Warna {item['warna']}, "
        f"Nomor Polisi {item['nopol']}, "
        f"Nomor Rangka"
    )

def _line1(doc, txt, align=WD_ALIGN_PARAGRAPH.LEFT):
    """Deskripsi kendaraan - Tab Dash di 16 cm."""
    p = _new_para(doc, left_cm=TAB_CM, first_cm=-TAB_CM, align=align)
    _add_tabstops(p, [
        (TAB_DESC_START, None, "left"),
        (POS_RIGHT, "dash", "right") # Menggunakan 16 cm
    ])
    _add_run(p, f"{txt}\t")
    return p
# ──────────────────────────────────────────────────────────────────
#  _label_line_triple  ← FIX v3.0
#
#  FORMAT LAMA (v2):
#    \t  [dash ke pos 3500]  Nilai Limit  \t  [dash ke pos 5500]  : Rp.X,00  \t  [dash ke right]
#    → "---Nilai Limit---: Rp. X,00---"   ← SALAH
#
#  FORMAT BARU (v3):
#    Nilai Limit  \t  [dash ke pos 5500]  : Rp.X,00.
#    → "Nilai Limit---------: Rp. X,00."  ← BENAR
#
#  Perubahan:
#    1. Hapus tab stop pertama (pos 3500 dengan leader) → tidak ada dash sebelum label
#    2. Hapus \t pertama dari teks         → label langsung mulai kiri (setelah indent)
#    3. Hapus \t terakhir dari teks        → tidak ada trailing dash setelah value
#    4. Efek samping: Pembeli alamat panjang tidak lagi memotong dash di tengah baris
# ──────────────────────────────────────────────────────────────────

def _label_line_triple(doc, label, value, align=WD_ALIGN_PARAGRAPH.LEFT):
    """Seksi 1: Nilai Limit - Tab Dash di 16 cm."""
    target_indent_twips = POS_COLON + 240 
    left_cm = target_indent_twips / 567
    first_line_cm = (POS_LABEL_L - target_indent_twips) / 567
    
    p = _new_para(doc, left_cm=left_cm, first_cm=first_line_cm, align=align)
    # Gunakan POS_RIGHT yang sudah kita set di 16 cm
    _add_tabstops(p, [(POS_COLON, "dash", "left"), (POS_RIGHT, "dash", "right")])
    _add_run(p, f"{label}\t: {value}\t")
    return p

def _label_pembeli(doc, label, value, align=WD_ALIGN_PARAGRAPH.LEFT):
    """Seksi 2: Pembeli - Tab Dash di 16 cm."""
    target_indent_twips = TAB_TWIPS
    left_cm = target_indent_twips / 567
    first_line_cm = (POS_PEMBELI_L - target_indent_twips) / 567
    
    p = _new_para(doc, left_cm=left_cm, first_cm=first_line_cm, align=align)
    _add_tabstops(p, [(POS_COLON, "dash", "left"), (POS_RIGHT, "dash", "right")])
    _add_run(p, f"{label}\t: {value}\t")
    return p

def add_lot_entry(doc, item: dict, section: str, seq_num: int = None):
    """Fungsi tunggal untuk memproses setiap lot lelang."""
    lot_num   = item.get("lot", 0)
    no_rangka = item.get("no_rangka", "-")
    no_mesin  = item.get("no_mesin", "-")
    desc      = _build_description(item)
    
    # FIX: Definisi list_num untuk nomor urut 1, 2, 3...
    list_num  = seq_num if seq_num is not None else lot_num
    
    # Prefix untuk Seksi 2 & 3
    lot_pfx   = f"Lot {lot_num}, " if section in ("SOLD", "TAP") else ""

    if section == "LIMIT":
        val = format_rupiah(item.get("limit", 0))
        _line1(doc, f"{list_num}.\t{desc} {no_rangka}, Nomor Mesin {no_mesin},")
        _label_line_triple(doc, "Nilai Limit", f"{val}.")

    elif section == "SOLD":
        val = format_rupiah(item.get("harga_terbentuk", 0))
        pembeli = f"{item.get('nama_customer', '-')}, beralamat di {item.get('alamat_customer', '-')}"
        
        _line1(doc, f"{list_num}.\t{lot_pfx}{desc} {no_rangka}, Nomor Mesin {no_mesin},")
        _label_line_triple(doc, "Harga Lelang", f"{val}.")
        _label_pembeli(doc, "Pembeli", f"{pembeli}.")

    elif section == "TAP":
        _line1(doc, f"{list_num}.\t{lot_pfx}{desc} {no_rangka}, Nomor Mesin {no_mesin}.", align=WD_ALIGN_PARAGRAPH.JUSTIFY)
        p = _new_para(doc, left_cm=TAB_CM, align=WD_ALIGN_PARAGRAPH.JUSTIFY)
        # Tab Dash tengah di 8 cm, Tab Dash akhir di 16 cm
        _add_tabstops(p, [
            (int(POS_RIGHT/2), "dash", "center"), 
            (POS_RIGHT, "dash", "right")
        ])
        _add_run(p, "\tTAP\t")


# ══════════════════════════════════════════════════════════════════
#  FOOTER BUILDER  ← NEW v3.0
#
#  Menggunakan nested Word IF fields dengan { PAGE } untuk
#  menghasilkan ordinal Indonesia otomatis per halaman:
#    Halaman 1 → "Pertama"
#    Halaman 2 → "Kedua"
#    ... dst sampai "Kelimabelas" (halaman 15)
#
#  Struktur XML nested IF:
#    { IF { PAGE } = 1 "Pertama" { IF { PAGE } = 2 "Kedua" ... } }
#
#  Word akan me-refresh field ini saat dokumen dibuka atau Ctrl+A → F9.
# ══════════════════════════════════════════════════════════════════

def _make_xml_run(text=None, is_instr=False, fld_char_type=None,
                  size_half_pt=20, bold=False, italic=False):
    """
    Helper: buat <w:r> element untuk footer (tidak pakai Document API).
    Mendukung: teks biasa, instrText field, fldChar.
    """
    r = OxmlElement("w:r")
    rPr = OxmlElement("w:rPr")
    rf = OxmlElement("w:rFonts")
    for attr in ("w:ascii", "w:hAnsi", "w:cs", "w:eastAsia"):
        rf.set(qn(attr), FONT_NAME)
    sz = OxmlElement("w:sz")
    sz.set(qn("w:val"), str(size_half_pt))
    rPr.append(rf)
    rPr.append(sz)
    if bold:
        b_el = OxmlElement("w:b")
        rPr.append(b_el)
    if italic:
        i_el = OxmlElement("w:i")
        rPr.append(i_el)
    r.append(rPr)

    if fld_char_type is not None:
        fc = OxmlElement("w:fldChar")
        fc.set(qn("w:fldCharType"), fld_char_type)
        r.append(fc)
    elif is_instr:
        it = OxmlElement("w:instrText")
        it.set("{http://www.w3.org/XML/1998/namespace}space", "preserve")
        it.text = str(text)
        r.append(it)
    else:
        t = OxmlElement("w:t")
        s = str(text) if text is not None else ""
        if s.startswith(" ") or s.endswith(" "):
            t.set("{http://www.w3.org/XML/1998/namespace}space", "preserve")
        t.text = s
        r.append(t)
    return r


def _make_page_field_runs(**kwargs):
    """Buat runs untuk field { PAGE } (5 runs: begin/instr/separate/cached/end)."""
    return [
        _make_xml_run(fld_char_type="begin", **kwargs),
        _make_xml_run(" PAGE ", is_instr=True, **kwargs),
        _make_xml_run(fld_char_type="separate", **kwargs),
        _make_xml_run("1", **kwargs),
        _make_xml_run(fld_char_type="end", **kwargs),
    ]


def _build_nested_if_ordinal(parent_el, ordinal_list, **run_kwargs):
    """
    Rekursif: bangun nested IF { PAGE } = N "OrdinalN" { IF ... } di parent_el.

    Struktur akhir untuk [1="Pertama", 2="Kedua", 3="Ketiga"]:
      [outer_begin][IF instr][{PAGE}][ = 1 "Pertama" instr]
        [inner_begin][IF instr][{PAGE}][ = 2 "Kedua" instr]
          [inner2_begin][IF instr][{PAGE}][ = 3 "Ketiga" "Berikutnya" instr]
          [separate][Ketiga][inner2_end]
        [separate][Kedua][inner_end]
      [separate][Pertama][outer_end]

    Word mengevaluasi mulai dari IF terluar. Hasilnya otomatis sesuai
    nomor halaman saat dokumen di-refresh (Ctrl+A → F9 atau buka di Word).
    """
    if not ordinal_list:
        return

    page_num, ordinal = ordinal_list[0]
    remaining = ordinal_list[1:]

    # Buka field IF ini
    parent_el.append(_make_xml_run(fld_char_type="begin", **run_kwargs))
    parent_el.append(_make_xml_run(" IF ", is_instr=True, **run_kwargs))

    # Kondisi: { PAGE }
    for r in _make_page_field_runs(**run_kwargs):
        parent_el.append(r)

    if remaining:
        # True value + false value = nested IF selanjutnya
        parent_el.append(_make_xml_run(f" = {page_num} \"{ordinal}\" ",
                                        is_instr=True, **run_kwargs))
        _build_nested_if_ordinal(parent_el, remaining, **run_kwargs)
    else:
        # Terakhir: true + false "Berikutnya" sebagai fallback
        parent_el.append(_make_xml_run(
            f" = {page_num} \"{ordinal}\" \"Berikutnya\" ",
            is_instr=True, **run_kwargs))

    # Tutup field IF ini (separate + cached + end)
    parent_el.append(_make_xml_run(fld_char_type="separate", **run_kwargs))
    parent_el.append(_make_xml_run(ordinal, **run_kwargs))
    parent_el.append(_make_xml_run(fld_char_type="end", **run_kwargs))


def _add_footer(doc: Document, meta: dict):
    """
    Tambah footer ke setiap halaman dokumen.

    Isi per halaman:
      ─────────────────────── (garis pemisah)
      Lembar [Kedua/Ketiga/...] dari Risalah Lelang Nomor X tanggal Y
                                        Pejabat Lelang Kelas II,

                                        ttd

                                        [Nama Pejabat]

    Ordinal "Kedua", "Ketiga", ... dihasilkan otomatis menggunakan
    nested Word IF { PAGE } field — tidak perlu di-hardcode per halaman.
    """
    nomor    = meta.get("nomor_risalah", "027/10/19/2026")
    tgl_raw  = meta.get("tanggal_lelang", "(18-02-2026)")
    tgl_short = _extract_short_date(tgl_raw)
    pejabat  = meta.get("nama_pejabat", "Rino Arief Rachman, S.H., M.H., M.Kn")

    section = doc.sections[0]
    footer  = section.footer
    ft      = footer._element   # <w:ftr> element

    # ── Bersihkan paragraf bawaan ─────────────────────────────────
    for p_elem in list(ft.findall(qn("w:p"))):
        ft.remove(p_elem)

    # ── Helper: buat <w:p> kosong di footer ──────────────────────
    def _new_ft_para(align="left", sp_before=0, sp_after=0, line_single=True):
        p = OxmlElement("w:p")
        pPr = OxmlElement("w:pPr")
        sp = OxmlElement("w:spacing")
        sp.set(qn("w:before"), str(int(sp_before * 20)))
        sp.set(qn("w:after"),  str(int(sp_after  * 20)))
        if line_single:
            sp.set(qn("w:line"),     "240")
            sp.set(qn("w:lineRule"), "auto")
        pPr.append(sp)
        if align != "left":
            jc = OxmlElement("w:jc")
            jc.set(qn("w:val"), align)
            pPr.append(jc)
        p.append(pPr)
        ft.append(p)
        return p

    SIZE = 20   # 10pt dalam half-points

    # ── Baris 1: Garis pemisah ────────────────────────────────────
    p_sep = _new_ft_para(sp_before=0, sp_after=0)
