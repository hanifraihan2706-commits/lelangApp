# Tambahkan alias sebanyak mungkin untuk mendukung berbagai template

COLUMN_ALIASES = {
    "lot": ["LOT", "ITEM LOT", "LOT ID", "NO LOT"],
    "nopol": ["NOPOL", "POLICE NUMBER", "NOMOR POLISI", "NO. POL", "PLAT"],
    "merk": ["MERK", "MEREK", "BRAND"],
    "model": ["MODEL", "TYPE", "TIPE", "MERK TYPE", "SERIES"],
