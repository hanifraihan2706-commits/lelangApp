    "tahun": ["TAHUN", "YEAR"],
    "warna": ["WARNA", "COLOR"],
    "status": ["STATUS", "KETERANGAN"],
    "nama_customer": ["PEMBELI", "NAMA CUSTOMER", "CUSTOMER NAME", "PEMENANG"],
