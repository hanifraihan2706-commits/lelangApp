    "open_price": ["HARGA AWAL", "HARGA AWAL ALL", "BASIC PRICE ALL", "OPEN PRICE", "BASIC PRICE", "LIMIT", "NILAI LIMIT"],
    "harga_terbentuk": ["HARGA LELANG", "HARGA TERBENTUK", "AUCTION PRICE", "RESULT PRICE", "LAKU"],
}

def _find_header_and_map(ws, log) -> tuple:
    header_idx = -1
    col_map = {}
    # Scan 15 baris pertama untuk mencari header
    for idx, row in enumerate(ws.iter_rows(min_row=1, max_row=15, values_only=True), start=1):
        row_strs = [str(cell).strip().upper() for cell in row if cell is not None]
        
        # Logika Fleksibel: Cari baris yang mengandung kata "LOT" di kolom mana saja
        if any("LOT" in s for s in row_strs):
            header_idx = idx
            for col_i, cell in enumerate(row):
                if cell is None: continue
                cell_val = str(cell).strip().upper()
                for key, aliases in COLUMN_ALIASES.items():
                    if key not in col_map:
                        # Cek apakah alias ada di dalam nama kolom (partial match)
                        if any(alias in cell_val for alias in aliases):
                            col_map[key] = col_i
            break
    return header_idx, col_map

def _find_header_and_map(ws, log) -> tuple:
    header_idx = -1
    col_map = {}
    # Scan 15 baris pertama untuk mencari baris header
    for idx, row in enumerate(ws.iter_rows(min_row=1, max_row=15, values_only=True), start=1):
        row_strs = [str(cell).strip().upper() for cell in row if cell is not None]
        
        # Cek apakah ada kolom yang mengandung kata "LOT" (misal: "Item Lot")
        if any("LOT" in s for s in row_strs):
            header_idx = idx
            for col_i, cell in enumerate(row):
                if cell is None: continue
                cell_val = str(cell).strip().upper()
                
                # Mapping kolom berdasarkan alias
                for key, aliases in COLUMN_ALIASES.items():
                    if key not in col_map:
                        if any(alias in cell_val for alias in aliases):
                            col_map[key] = col_i
            break
            
    if header_idx != -1:
        log(f"   🔍 Header terdeteksi otomatis pada baris ke-{header_idx}")
    return header_idx, col_map

def read_excel_data(excel_path: str, sheet_name: str, log_cb=None) -> list:
    def log(msg):
        if log_cb: log_cb(msg)

    wb = openpyxl.load_workbook(excel_path, data_only=True)
    ws = wb[sheet_name]
    jenis = "motor" if "MOTOR" in sheet_name.upper() else "mobil"

    header_idx, col_map = _find_header_and_map(ws, log)
    if header_idx == -1 or "lot" not in col_map:
        log("❌ Gagal mendeteksi kolom! Pastikan ada baris Header yang mengandung kata 'LOT'.")
        return []

    items = []
    # Mulai baca data dari satu baris setelah header
    for row in ws.iter_rows(min_row=header_idx + 1, values_only=True):
        def _get(col_key):
            idx = col_map.get(col_key, -1)
            if idx < 0 or idx >= len(row): return None
            return row[idx]

        # Fungsi pembantu untuk membersihkan format Rupiah di Excel (Rp. 1.000,00 -> 1000)
        def _get_numeric(col_key):
            val = _get(col_key)
            if val is None or val == "": return 0
            if isinstance(val, (int, float)): return float(val)
            try:
                # Bersihkan string: buang Rp, spasi, titik (ribuan), ubah koma ke titik (desimal)
                s_val = str(val).replace("Rp", "").replace(".", "").replace(",", ".").replace(" ", "").strip()
                return float(s_val) if s_val else 0
            except:
                return 0

        lot_val = _get("lot")
        if lot_val is None: continue
        try:
            lot_num = int(float(lot_val))
        except (ValueError, TypeError):
            continue

        model_raw = _get("model")
        no_mesin_raw = _get("no_mesin")
        
        if isinstance(no_mesin_raw, (float, int)):
            no_mesin_raw = str(int(no_mesin_raw))

        status_raw = safe_str(_get("status"), "Not Sold")
        status_norm = status_raw.strip().upper()

        # Mapping data ke dictionary dengan angka yang sudah bersih
        item = {
            "lot"             : lot_num,
            "nopol"           : safe_str(_get("nopol")),
            "merk"            : safe_str(_get("merk")),
            "model"           : safe_str(model_raw),
            "no_mesin"        : safe_str(no_mesin_raw),
            "no_rangka"       : safe_str(_get("no_rangka")),
            "tahun"           : safe_str(_get("tahun")),
            "warna"           : safe_str(_get("warna")),
            "status"          : status_norm,
            "nama_customer"   : safe_str(_get("nama_customer")),
            "alamat_customer" : safe_str(_get("alamat_customer")),
            "limit"           : _get_numeric("open_price"),     # FIX: Gunakan pembersih angka
            "harga_terbentuk" : _get_numeric("harga_terbentuk"), # FIX: Gunakan pembersih angka
            "jenis"           : jenis,
        }
        items.append(item)

    log(f"   ✅ Total lot terbaca: {len(items)}")
    return items

