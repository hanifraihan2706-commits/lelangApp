def add_para(doc, text, font_name, font_size, right_align=False,
             num_id=None, tab_right=True, right_cm=15.5):
    p   = doc.add_paragraph()
    run = p.add_run(text)
    run.font.name = font_name
    run.font.size = Pt(font_size)
    
    p.alignment = (WD_ALIGN_PARAGRAPH.RIGHT if right_align 
                   else WD_ALIGN_PARAGRAPH.JUSTIFY)
    
    pf = p.paragraph_format
    pf.space_before = Pt(0)
    pf.space_after  = Pt(0)
    pf.line_spacing = 1.0
    
    # Indentasi mengikuti nomor (0)
    if num_id is None:
        pf.left_indent = Cm(0)
        pf.first_line_indent = Cm(0)
    
    if tab_right:
        # Tab stop untuk garis putus-putus di sisi kanan
        p.paragraph_format.tab_stops.add_tab_stop(Cm(right_cm), WD_TAB_ALIGNMENT.RIGHT, WD_TAB_LEADER.DASHES)
        
    if num_id is not None:
        apply_numpr(p, num_id)
        
    return p

