    # ── Log helpers ───────────────────────────────────────────
    def _log(self, msg, tag=None):
        self.log_text.config(state='normal')
        ts = datetime.datetime.now().strftime('%H:%M:%S')
        line = f'[{ts}] {msg}\n'
        # Auto-tag based on content
        if tag is None:
            if any(k in msg for k in ('✅', 'SELESAI', 'tersimpan')):
                tag = 'ok'
            elif any(k in msg for k in ('⚠️', 'Dilewati')):
                tag = 'warn'
            elif any(k in msg for k in ('❌', 'Error', 'ERROR')):
                tag = 'err'
            elif any(k in msg for k in ('📝', '📊', '─', '🏗️', '📋', '📂', '🔢', '📄', '📃')):
                tag = 'hdr'
        if tag:
            self.log_text.insert('end', line, tag)
        else:
            self.log_text.insert('end', line)
        self.log_text.see('end')
        self.log_text.config(state='disabled')

    def _clear_log(self):
        self.log_text.config(state='normal')
        self.log_text.delete('1.0', 'end')
        self.log_text.config(state='disabled')
        self.progress['value'] = 0

    # ── File dialogs ──────────────────────────────────────────
    def _browse_excel(self):
        path = filedialog.askopenfilename(
            title='Pilih File Excel Laporan Lelang',
            filetypes=[('Excel Files', '*.xlsx *.xls'), ('All Files', '*.*')]
        )
        if path:
            self.excel_path.set(path)
            # Auto-set output dir to same folder as excel
            self.output_dir.set(os.path.dirname(path))
            self._log(f'File dipilih: {os.path.basename(path)}', tag='hdr')

    def _browse_output(self):
        path = filedialog.askdirectory(title='Pilih Folder Penyimpanan Output')
        if path:
            self.output_dir.set(path)

    # ── Generate ──────────────────────────────────────────────
    def _on_generate(self):
        # ... (bagian validasi awal tetap sama) ...
        excel = self.excel_path.get().strip()
        out_d  = self.output_dir.get().strip()
        
        # ... (bagian koleksi cfg tetap sama) ...
        # --- PASTIKAN BAGIAN INI DI DALAM _on_generate SEPERTI INI ---
    
        cfg = {
        'nomor_rl'      : self.nomor_rl.get().strip() or '???',
        'tanggal_rl'    : self.tanggal_rl.get().strip() or '???',
        'pejabat_kelas' : self.pej_kelas.get().strip() or 'Pejabat Lelang Kelas II,',
        'pejabat_nama'  : self.pej_nama.get().strip() or '???',
        'items_per_page': self.items_pp.get(),
        'font_name'     : 'Arial', # Pastikan pakai titik dua (:), bukan koma (,)
        'font_size'     : 12,      # Pastikan pakai titik dua (:), bukan koma (,)
        'page_w'        : 21.0,
        'page_h'        : 33.0,
        'mar_l'         : 4.0,
        'mar_r'         : 1.5,
        'mar_t'         : 2.0,
        'mar_b'         : 2.0,
    }

        # --- PERBAIKAN PENAMAAN FILE ---
        # Kita tidak lagi mengambil nama dari file Excel asli untuk menghindari karakter aneh
        date_str = datetime.datetime.now().strftime('%d-%m-%Y_%H-%M')
        # Nama file dibuat sederhana & aman untuk sistem
        clean_filename = f"Risalah_Lelang_{date_str}.docx"
        out_path = os.path.join(out_d, clean_filename)

        self.running = True
        self.btn_gen.config(state='disabled', text='⏳  Sedang Memproses...')
        self.progress['value'] = 0
        self.status_var.set('Memproses...')
        self._log('=' * 46, tag='hdr')
        self._log(f'MULAI GENERATE', tag='hdr')

        def _worker():
            try:
                def _log_cb(msg):
                    self.after(0, lambda m=msg: self._log(m))

                def _prog_cb(done, total):
                    pct = int(done / total * 100) if total > 0 else 0
                    self.after(0, lambda p=pct: self._set_progress(p))

                # Proses pembuatan dokumen
                generate_doc(excel, out_path, cfg, _log_cb, _prog_cb)

                self.after(0, self._on_success, out_path)

            except Exception as e:
                err_msg = str(e)
                tb = traceback.format_exc()
                self.after(0, self._on_error, err_msg, tb)

        t = threading.Thread(target=_worker, daemon=True)
        t.start()
    def _set_progress(self, pct):
        self.progress['value'] = pct
        self.status_var.set(f'Memproses... {pct}%')

    def _on_success(self, out_path):
        self.running = False
        self.progress['value'] = 100
        self.btn_gen.config(state='normal', text='▶  BUAT RISALAH LELANG')
        self.status_var.set('✅ Selesai!')
        
        ans = messagebox.askyesno(
            '✅ Berhasil!',
            f'Dokumen berhasil dibuat!\n\nBuka file sekarang?'
        )
        if ans:
            try:
                # Cara paling aman untuk macOS membuka file dengan spasi/karakter khusus
                import subprocess
                subprocess.call(('open', out_path))
            except Exception:
                pass

    def _on_error(self, msg, tb):
        self.running = False
        self.btn_gen.config(state='normal', text='▶  BUAT RISALAH LELANG')
        self.status_var.set('❌ Terjadi Error')
        self._log(f'❌ ERROR: {msg}', tag='err')
        self._log(tb, tag='err')
        messagebox.showerror(
            '❌ Terjadi Kesalahan',
            f'{msg}\n\nLihat panel Log untuk detail lengkap.'
        )


