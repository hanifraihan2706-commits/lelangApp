def new_num_id(doc, abs_id='0'):
    ne  = _num_el(doc)
    ids = [int(n.get(qn('w:numId'), 0)) for n in ne.findall(qn('w:num'))]
    nid = (max(ids) if ids else 0) + 1
    def el(tag, **a):
        e = OxmlElement(tag)
        for k, v in a.items():
            e.set(qn(k), str(v))
        return e
    num = el('w:num', **{'w:numId': str(nid)})
    num.append(el('w:abstractNumId', **{'w:val': abs_id}))
    ov = el('w:lvlOverride', **{'w:ilvl': '0'})
    ov.append(el('w:startOverride', **{'w:val': '1'}))
    num.append(ov)
    ne.append(num)
    return nid

def apply_numpr(para, num_id):
    pPr   = para._p.get_or_add_pPr()
    old   = pPr.find(qn('w:numPr'))
    if old is not None:
        pPr.remove(old)
    numPr = OxmlElement('w:numPr')
    ilvl  = OxmlElement('w:ilvl')
    ilvl.set(qn('w:val'), '0')
    nid_el = OxmlElement('w:numId')
    nid_el.set(qn('w:val'), str(num_id))
    numPr.append(ilvl)
    numPr.append(nid_el)
    pPr.insert(0, numPr)
                               
def _set_tabs(para, tab_config):
    para.paragraph_format.tab_stops.clear_all()
    for pos, align, leader in tab_config:
        para.paragraph_format.tab_stops.add_tab_stop(pos, align, leader)

def format_auction_multiline(text, mode="LIMIT"):
    if not text: return text
    clean_txt = re.sub(r'\s+', ' ', text).strip()
    
    # Filler untuk menutup celah dari margin kiri ke teks
    filler = "------------------" 
    
    patterns = {
        "LIMIT": r"(.*?)(Nilai Limit)\s*[:\-]*\s*(.*)",
        "SOLD":  r"(.*?)(Harga Lelang)\s*[:\-]*\s*(.*?)(Pembeli)\s*[:\-]*\s*(.*)",
        "TAP":   r"(.*)(TAP|Tidak Terjual)(.*)"
    }
    
    try:
        if mode == "LIMIT":
            match = re.match(patterns["LIMIT"], clean_txt, re.IGNORECASE)
            if match:
                desc, label, val = match.groups()
                # \t baris pertama agar teks bergeser dari nomor
                # Baris kedua dimulai filler agar menutup margin kiri
                return f"\t{desc.strip()}\n{filler} {label.strip()}\t: {val.strip()}"
        
        elif mode == "SOLD":
            match = re.match(patterns["SOLD"], clean_txt, re.IGNORECASE)
            if match:
                desc, lh, vh, lp, vp = match.groups()
                return (f"\t{desc.strip()}\n{filler} {lh.strip()}\t: {vh.strip()}\n"
                        f"{filler} {lp.strip()}\t: {vp.strip()}")
        
        elif mode == "TAP":
             return f"\t{clean_txt}\t"

    except:
        pass
    return f"\t{clean_txt}\t"

