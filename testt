def fix_rp(text):
    if not text:
        return text
    def _repl(m):
        n = m.group(1).replace(',', '')
        s = str(int(n))
        res = ''
        for i, c in enumerate(s):
            if i > 0 and (len(s) - i) % 3 == 0:
                res += '.'
            res += c
        return 'Rp. ' + res + ',00'
    return re.sub(r'([\d,]+)\.Rp \.00', _repl, text)

def get_ordinal(n):
    if 1 <= n <= len(ORDINAL_ID) - 1:
        return ORDINAL_ID[n]
    return f'Ke-{n}'

def find_sheet(wb, log):
    names = wb.sheetnames
    for n in names:
        if n.strip().upper() == 'FIRMAN':
            log(f'  📋 Sheet: "{n}" (ditemukan otomatis)')
            return wb[n]
    for n in names:
        if 'FIRMAN' in n.strip().upper():
            log(f'  📋 Sheet: "{n}" (mengandung FIRMAN)')
            return wb[n]
    log(f'  ⚠️  Sheet "FIRMAN" tidak ada. Tersedia: {names}')
    log(f'  📋 Menggunakan sheet pertama: "{names[0]}"')
    return wb[names[0]]

def find_header_row(ws):
    best_idx   = -1
    best_score = 0
    best_cols  = {}
    for row_i, row in enumerate(ws.iter_rows(max_row=20, values_only=True)):
        cells    = [str(c).strip() if c is not None else '' for c in row]
        cells_lo = [c.lower() for c in cells]
        cols     = {f: -1 for f in COL_MATCH}
        score    = 0
        for field, patterns in COL_MATCH.items():
            for kw in patterns['exact']:
                for i, c in enumerate(cells_lo):
                    if c == kw:
                        cols[field] = i
                        score += 2
                        break
                if cols[field] != -1:
                    break
            if cols[field] == -1:
                for kw in patterns['contains']:
                    for i, c in enumerate(cells_lo):
                        if kw in c and c:
                            cols[field] = i
                            score += 1
                            break
                    if cols[field] != -1:
                        break
        if score > best_score:
            best_score = score
            best_idx   = row_i + 1
            best_cols  = cols.copy()
    return best_idx, best_cols

def _classify_one(val):
    v     = val.lower().strip()
    words = set(v.replace('-', ' ').split())
    if any(kw in v for kw in KW_SKIP):
        return 'skip'
    if words & NEGATION_WORDS:
        return 'tap'
    if words & KW_SOLD_SET:
        return 'sold'
    return 'tap'

def detect_status(ws, status_col, data_start, log):
    if status_col == -1:
        log('  ⚠️  Kolom STATUS tidak ditemukan.')
        return {}
    unique = set()
    for row in ws.iter_rows(min_row=data_start, values_only=True):
        if len(row) > status_col and row[status_col] is not None:
            unique.add(str(row[status_col]).strip())
    mapping   = {val: _classify_one(val) for val in unique}
    sold_vals = sorted(k for k, v in mapping.items() if v == 'sold')
    tap_vals  = sorted(k for k, v in mapping.items() if v == 'tap')
    skip_vals = sorted(k for k, v in mapping.items() if v == 'skip')
    log(f'  ✅ Status Laku Terjual : {sold_vals}')
    log(f'  ✅ Status Tidak Laku   : {tap_vals}')
    if skip_vals:
        log(f'  ⏭️  Dilewati (Skip)     : {skip_vals}')
    return mapping

def read_excel(filename, log):
    log(f'📂 Membaca file: {os.path.basename(filename)}')
    wb = load_workbook(filename, data_only=True)
    ws = find_sheet(wb, log)
    hrow, col = find_header_row(ws)
    if hrow == -1:
        raise ValueError('Baris header tidak ditemukan di file Excel.')
    log(f'  🔎 Header ditemukan di baris {hrow}')
    log(f'  🗂  Kolom — LOT:{col["LOT"]} STATUS:{col["STATUS"]} '
        f'LIMIT:{col["LIMIT"]} LAKU:{col["LAKU"]} TAP:{col["TAP"]}')
    missing = [f for f in col if col[f] == -1]
    if missing:
        raise ValueError(
            f'Kolom tidak ditemukan: {missing}\n'
            'Pastikan header Excel memiliki kolom bernama:\n'
            '"Lot", "Status", "Limit", "Laku", "TAP"'
        )
    data_start  = hrow + 1
    status_map  = detect_status(ws, col['STATUS'], data_start, log)

    def gv(row, idx):
        if idx == -1 or len(row) <= idx or row[idx] is None:
            return ''
        v = row[idx]
        if isinstance(v, float) and v == int(v):
            return str(int(v))
        return str(v).strip()

    all_rows  = []
    sold_rows = []
    tap_rows  = []
    skipped   = 0

    for row in ws.iter_rows(min_row=data_start, values_only=True):
        lot_raw = row[col['LOT']] if len(row) > col['LOT'] else None
        if not lot_raw or str(lot_raw).strip() in ('', 'None'):
            continue
        try:
            lot = str(int(round(float(str(lot_raw)))))
        except (ValueError, TypeError):
            continue

        status_raw = gv(row, col['STATUS'])
        stype      = status_map.get(status_raw, 'tap')

        if stype == 'skip':
            skipped += 1
            continue

        r = {
            'lot'      : lot,
            'stype'    : stype,
            'limit_txt': fix_rp(gv(row, col['LIMIT'])),
            'laku_txt' : fix_rp(gv(row, col['LAKU'])),
            'tap_txt'  : fix_rp(gv(row, col['TAP'])),
        }
        all_rows.append(r)
        if stype == 'sold':
            sold_rows.append(r)
        else:
            tap_rows.append(r)

    log(f'\n  📊 Total: {len(all_rows)} LOT  |  '
        f'Laku: {len(sold_rows)}  |  TAP: {len(tap_rows)}'
        + (f'  |  Dilewati: {skipped}' if skipped else ''))
    return all_rows, sold_rows, tap_rows

