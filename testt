def _num_el(doc):
    try:
        return doc.part.numbering_part._element
    except Exception:
        from docx.parts.numbering import NumberingPart
        np = NumberingPart.new()
        doc.part.relate_to(
            np,
            'http://schemas.openxmlformats.org/officeDocument/2006/relationships/numbering'
        )
        return np._element

