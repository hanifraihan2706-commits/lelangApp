def generate_doc(excel_path, output_path, cfg, log, progress_cb):
    t0      = time.time()
    fn      = cfg['font_name']
    fs      = cfg['font_size']
    ipp     = cfg['items_per_page']
    right_w = cfg['page_w'] - cfg['mar_l'] - cfg['mar_r']

    log('─' * 50)
    all_rows, sold_rows, tap_rows = read_excel(excel_path, log)

    log('\n🏗️  Membuat dokumen Word...')
    try:
        doc = Document()
    except Exception as e:
        log(f"❌ Gagal inisialisasi Word: {str(e)}", tag='err')
        raise e
        
    sec = doc.sections[0]
    sec.page_width, sec.page_height = Cm(cfg['page_w']), Cm(cfg['page_h'])
    sec.left_margin, sec.right_margin = Cm(cfg['mar_l']), Cm(cfg['mar_r'])
    sec.top_margin, sec.bottom_margin = Cm(cfg['mar_t']), Cm(cfg['mar_b'])

    abs_id = setup_abstract_num(doc, fn, fs)
    nid_s1 = new_num_id(doc, abs_id)
    nid_s2 = new_num_id(doc, abs_id)
    nid_s3 = new_num_id(doc, abs_id)

    ps    = PageState()
    total = len(all_rows) + len(sold_rows) + len(tap_rows)
    done  = [0]

    def _para(text, num_id=None, tab_right=True):
        return add_para(doc, text, fn, fs, num_id=num_id,
                        tab_right=tab_right, right_cm=right_w)

    # --- SECTION 1: NILAI LIMIT ---
    log(f'\n📝 Section 1 — {len(all_rows)} item...')
    for r in all_rows:
        ps.check_break(doc, cfg, fn, fs, ipp)
        raw_text = r['limit_txt'] or f"Lot {r['lot']}, (data tidak tersedia)"
        text_ready = format_auction_multiline(raw_text, mode="LIMIT")
        _para(text_ready, num_id=nid_s1)
        ps.tick()
        done[0] += 1
        progress_cb(done[0], total)

    # --- SECTION 2: LAKU TERJUAL ---
    if sold_rows:
        log(f'📝 Section 2 — {len(sold_rows)} item Laku...')
        ps.check_break(doc, cfg, fn, fs, ipp)
        _para('Barang laku terjual:\t', tab_right=False)
        ps.tick()
        for r in sold_rows:
            ps.check_break(doc, cfg, fn, fs, ipp)
            raw_text = r['laku_txt'] or f"Lot {r['lot']}, (data tidak tersedia)"
            text_ready = format_auction_multiline(raw_text, mode="SOLD")
            _para(text_ready, num_id=nid_s2)
            ps.tick()
            done[0] += 1
            progress_cb(done[0], total)

    # --- SECTION 3: TAP ---
    if tap_rows:
        log(f'📝 Section 3 — {len(tap_rows)} item TAP...')
        ps.check_break(doc, cfg, fn, fs, ipp)
        _para('Barang tidak laku terjual:\t', tab_right=False)
        ps.tick()
        for i, r in enumerate(tap_rows):
            ps.check_break(doc, cfg, fn, fs, ipp, is_last=(i == len(tap_rows) - 1))
            raw_text = r['tap_txt'] or f"Lot {r['lot']}, (data tidak tersedia)"
            text_ready = format_auction_multiline(raw_text, mode="TAP")
            _para(text_ready, num_id=nid_s3)
            ps.tick()
            done[0] += 1
            progress_cb(done[0], total)

    doc.save(output_path)
    elapsed = time.time() - t0
    log(f'\n✅ SELESAI dalam {elapsed:.1f} detik')
    return output_path


